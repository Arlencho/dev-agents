.env
.env.*
!.env.example
.DS_Store
node_modules/

# Agent logs (collected from workers)
logs/*.log
!logs/.gitkeep

# Wave plan execution logs contain timestamps, keep .plan files
wave-plans/*.log
!wave-plans/.gitkeep

# Learnings data (generated at runtime, contains project-specific JSONL)
learnings/*.jsonl
!learnings/.gitkeep
